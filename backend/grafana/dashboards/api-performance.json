      "type": "stat",
      "title": "Latence P99 (global)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate({__name__=~\"${app}_http_request_duration_seconds_bucket\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "A"
