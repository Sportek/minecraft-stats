{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "author": "Sportek aka Gabriel Landry",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "build:docker": "docker build -t sportek/minecraft-stats-back:latest .",
    "run:docker": "docker run -p 9000:9000 sportek/minecraft-stats-back:latest",
    "start:docker": "docker compose --env-file ./.env.production up -d",
    "stop:docker": "docker compose down"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#tests/*": "./tests/*.js",
    "#config/*": "./config/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#transformers/*": "./app/transformers/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/api-client": "^3.2.1",
    "@japa/assert": "^4.2.0",
    "@japa/plugin-adonisjs": "^5.2.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/leb128": "^0.0.0",
    "@types/luxon": "^3.7.1",
    "@types/mcping-js": "^1.5.4",
    "@types/node": "^20.12.10",
    "adonis-sail": "^1.0.0",
    "eslint": "^10.5.0",
    "hot-hook": "^0.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.4",
    "typescript": "^6.0.3",
    "youch": "^4.1.1"
  },
  "dependencies": {
    "@adonisjs/ally": "^6.3.0",
    "@adonisjs/auth": "^10.1.0",
    "@adonisjs/bouncer": "^4.0.0",
    "@adonisjs/core": "^7.3.1",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/limiter": "^3.0.1",
    "@adonisjs/lucid": "^22.4.2",
    "@adonisjs/mail": "^10.2.0",
    "@adonisjs/redis": "^10.0.0",
    "@adonisjs/static": "^2.0.1",
    "@julr/adonisjs-prometheus": "^2.1.0",
    "@minescope/mineping": "^2.0.0",
    "@swc/wasm": "^1.5.24",
    "@vinejs/vine": "^4.3.1",
    "adonis-autoswagger": "^3.64.0",
    "adonisjs-scheduler": "^2.6.4",
    "argon2": "^0.44.0",
    "edge.js": "^6.5.0",
    "jsonwebtoken": "^9.0.2",
    "leb128": "^0.0.5",
    "luxon": "^3.7.2",
    "mcping-js": "^1.5.0",
    "mjml": "^5.3.0",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.35.2"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config",
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
