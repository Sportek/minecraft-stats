# URL de base de l'API Minecraft Stats (sans slash final).
# En local : http://localhost:3333 — en Docker : http://adonis_app:3333
API_BASE_URL=http://localhost:3333

# URL du spec OpenAPI (défaut : ${API_BASE_URL}/swagger). À surcharger seulement
# si le spec est servi ailleurs.
# OPENAPI_URL=http://localhost:3333/swagger

# Port et interface d'écoute du serveur MCP.
PORT=3334
HOST=0.0.0.0

# Chemin HTTP du endpoint MCP (transport Streamable HTTP).
MCP_PATH=/mcp

# Timeout (ms) des appels en proxy vers le backend.
PROXY_TIMEOUT_MS=15000

# Protection contre le DNS rebinding (recommandé en production).
# Listes séparées par des virgules. Laisser vide désactive la protection (dev local).
# Exemple : ALLOWED_HOSTS=mcp.minecraft-stats.fr
# ALLOWED_HOSTS=
# ALLOWED_ORIGINS=
